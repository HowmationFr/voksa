{
  "name": "voksa",
  "productName": "Voksa",
  "version": "0.2.0",
  "description": "Voksa",
  "author": "Voksa",
  "license": "GPL-3.0-only",
  "repository": "github:HowmationFr/voksa",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "postinstall": "patch-package && electron-rebuild -f -w better-sqlite3",
    "dev": "node scripts/dev.mjs",
    "build": "npm run build:ui && npm run build:main",
    "build:ui": "vite build",
    "build:main": "node scripts/build-main.mjs",
    "gen:credits": "node scripts/gen-credits.mjs",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@eslint/js": "^9.12.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^38.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.24.0",
    "eslint": "^9.12.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.0.7",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1",
    "vite": "^5.4.8",
    "vitest": "^2.1.2",
    "ws": "^8.21.0",
    "zustand": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
